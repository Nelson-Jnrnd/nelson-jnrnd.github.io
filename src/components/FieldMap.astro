---
// Compact folded-map navigation — always visible in small form,
// unfolds into the full treasure map on hover / focus / tap.
---

<div class="mapnav" id="mapnav">
  <button
    type="button"
    class="mapnav__toggle"
    aria-expanded="false"
    aria-controls="mapnav-panel"
    aria-label="Open site map navigation"
  >
    <span class="mapnav__icon">
      <svg viewBox="0 0 18 16" aria-hidden="true">
        <path d="M 1.2 2.5 L 6.6 1 L 11.4 2.5 L 16.8 1 V 13.5 L 11.4 15 L 6.6 13.5 L 1.2 15 Z"></path>
        <line x1="6.6" y1="1" x2="6.6" y2="13.5" stroke-dasharray="1 1.4"></line>
        <line x1="11.4" y1="2.5" x2="11.4" y2="15" stroke-dasharray="1 1.4"></line>
        <path d="M 8.2 6.5 l 1.6 1.8 M 8.2 8.3 l 1.6 -1.8" stroke="rgba(168,65,46,0.9)" stroke-width="1"></path>
      </svg>
    </span>
    <span class="mapnav__label">Field map</span>
    <span class="mapnav__caret">▾</span>
  </button>

  <div class="mapnav__panel" id="mapnav-panel" role="region" aria-label="Site map">
    <nav class="treasure" aria-label="Site sections">
      <div class="treasure__header">
        <div class="treasure__title">Field map <span class="annot">— route 01</span></div>
        <span class="meta">N&nbsp;↑</span>
      </div>
      <div class="treasure__scene">
        <svg class="treasure__svg" viewBox="0 0 400 300" aria-hidden="true">
          <defs>
            <pattern id="tm-hatch" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
              <line x1="0" y1="0" x2="0" y2="6" stroke="rgba(120,80,30,0.18)" stroke-width="0.6"></line>
            </pattern>
          </defs>
          <path
            d="M 30 200 Q 70 160 130 175 T 240 170 Q 300 165 360 195 Q 380 230 350 255 Q 280 280 200 270 Q 110 260 50 250 Z"
            fill="url(#tm-hatch)"
            stroke="rgba(120,80,30,0.25)"
            stroke-width="0.8"
            stroke-dasharray="2 3"
            opacity="0.55"></path>
          <path
            d="M 50 80 Q 90 50 160 60 Q 230 70 270 55 Q 330 45 360 70 Q 365 95 330 105 Q 260 115 200 110 Q 130 105 70 115 Q 45 110 50 80 Z"
            fill="rgba(229,210,170,0.45)"
            stroke="rgba(120,80,30,0.3)"
            stroke-width="0.8"
            stroke-dasharray="2 3"
            opacity="0.7"></path>
          <g stroke="rgba(80,110,140,0.25)" stroke-width="0.7" fill="none" stroke-linecap="round">
            <path d="M 20 145 q 8 -4 16 0 t 16 0 t 16 0"></path>
            <path d="M 290 130 q 8 -4 16 0 t 16 0 t 16 0"></path>
            <path d="M 200 220 q 8 -4 16 0 t 16 0"></path>
          </g>
          <path
            d="M 70 90 Q 200 50 320 100 Q 380 170 285 235 Q 200 270 80 220"
            fill="none"
            stroke="rgba(168,65,46,0.85)"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-dasharray="2 5"></path>
          <g stroke="rgba(168,65,46,0.75)" stroke-width="1.3" stroke-linecap="round" fill="none">
            <path d="M 195 75 l 4 4 M 195 79 l 4 -4"></path>
            <path d="M 340 165 l 4 4 M 340 169 l 4 -4"></path>
            <path d="M 145 240 l 4 4 M 145 244 l 4 -4"></path>
          </g>
          <g transform="translate(355 250)" stroke="rgba(60,40,10,0.55)" fill="none" stroke-width="0.9" stroke-linecap="round">
            <circle cx="0" cy="0" r="14"></circle>
            <path d="M 0 -16 L 3 0 L 0 16 L -3 0 Z" fill="rgba(60,40,10,0.7)" stroke="none"></path>
            <path d="M -16 0 L 0 -3 L 16 0 L 0 3 Z" fill="rgba(60,40,10,0.35)" stroke="none"></path>
            <text x="0" y="-19" font-family="IBM Plex Mono" font-size="7" fill="rgba(60,40,10,0.7)" text-anchor="middle" stroke="none">N</text>
          </g>
          <text x="38" y="40" font-family="Source Serif 4" font-style="italic" font-size="9" fill="rgba(60,40,10,0.55)" stroke="none">~ here be drafts ~</text>
        </svg>

        <a class="tm-pin" href="#work" aria-label="Go to Work" style="left: 18%; top: 30%;">
          <span class="tm-pin__marker">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <line x1="10" y1="6" x2="10" y2="28"></line>
              <path class="filled" d="M 10 6 L 24 9 L 18 13 L 24 17 L 10 17 Z"></path>
            </svg>
          </span>
          <span class="tm-pin__label">Work</span>
        </a>
        <a class="tm-pin" href="#toolkit" aria-label="Go to Toolkit" style="left: 80%; top: 36%;">
          <span class="tm-pin__marker">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <line x1="6" y1="26" x2="26" y2="6"></line>
              <line x1="6" y1="6" x2="26" y2="26"></line>
              <rect x="4" y="20" width="8" height="6" rx="1" transform="rotate(-45 8 23)" class="filled"></rect>
              <rect x="20" y="20" width="8" height="6" rx="1" transform="rotate(45 24 23)" class="filled"></rect>
            </svg>
          </span>
          <span class="tm-pin__label">Toolkit</span>
        </a>
        <a class="tm-pin" href="#contact" aria-label="Go to Contact" style="left: 71%; top: 78%;">
          <span class="tm-pin__marker">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <rect x="5" y="10" width="22" height="14" rx="1"></rect>
              <path d="M 5 11 L 16 19 L 27 11"></path>
            </svg>
          </span>
          <span class="tm-pin__label">Contact</span>
        </a>
        <a class="tm-pin" href="#about" aria-label="Go to About" style="left: 20%; top: 74%;">
          <span class="tm-pin__marker">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M 6 26 L 16 8 L 26 26 Z"></path>
              <line x1="11" y1="26" x2="11" y2="18"></line>
              <line x1="21" y1="26" x2="21" y2="18"></line>
              <line x1="13" y1="22" x2="19" y2="22"></line>
            </svg>
          </span>
          <span class="tm-pin__label">About</span>
        </a>
      </div>
      <div class="treasure__footer">
        <span class="meta">04 waypoints</span>
        <span class="annot annot--green">↳ tap a pin</span>
      </div>
    </nav>
  </div>
</div>
