---
// About — short professional sketch + a subtle illustrated interest strip.
---

<section class="block about" id="about">
  <div class="wrap">
    <header class="section-head reveal">
      <span class="section-head__num">03 /</span>
      <h2 class="section-head__title">About</h2>
      <p class="section-head__caption">
        A short professional sketch — who I am, what I work with, and what I’m drawn to outside of work.
      </p>
    </header>

    <div class="about-grid">
      <div class="about-text reveal">
        <p>
          <strong>I’m Nelson Jeanrenaud</strong>, a software engineer based in Bussigny, Switzerland. I work mainly with
          C#/.NET, Blazor, WPF, Java, object-oriented design, and software architecture.
        </p>
        <p>
          My background includes R&amp;D software, industrial applications, backend development, teaching support in
          object-oriented programming and cloud computing, and a B.Sc. in Computer Science and Communication Systems from
          <strong>HEIG-VD</strong>, Software Development orientation, graduated in 2023.
        </p>
        <p>
          I like working on software that connects technical systems, real-world constraints, and clear user workflows. I’m
          especially interested in industrial tools, data workflows, simulation systems, and applications that need to stay
          <span class="highlight">understandable as they evolve</span>.
        </p>
      </div>
      <div class="about-media reveal">
        <figure class="polaroid">
          <div class="polaroid__frame">
            <!-- workbench sketch: notebook + pencil + coffee -->
            <svg class="sketch" viewBox="0 0 100 120" aria-hidden="true">
              <rect x="16" y="34" width="56" height="52" rx="2"></rect>
              <line x1="16" y1="44" x2="72" y2="44"></line>
              <line x1="22" y1="52" x2="66" y2="52"></line>
              <line x1="22" y1="58" x2="60" y2="58"></line>
              <line x1="22" y1="64" x2="64" y2="64"></line>
              <line x1="22" y1="70" x2="56" y2="70"></line>
              <line x1="22" y1="76" x2="62" y2="76"></line>
              <line x1="76" y1="40" x2="92" y2="62"></line>
              <polygon points="74,38 78,42 76,40"></polygon>
              <path d="M22 92h32v14a4 4 0 0 1-4 4H26a4 4 0 0 1-4-4z"></path>
              <path d="M54 96h6a4 4 0 0 1 0 8h-6"></path>
              <line x1="28" y1="86" x2="28" y2="90"></line>
              <line x1="36" y1="86" x2="36" y2="90"></line>
              <line x1="44" y1="86" x2="44" y2="90"></line>
            </svg>
          </div>
          <figcaption class="polaroid__caption">
            <strong>workbench — placeholder</strong>
            <span>4:5</span>
          </figcaption>
        </figure>
      </div>
    </div>

    <!-- ─── Interest strip ────────────────────────── -->
    <div class="interests reveal">
      <div class="interests__label">
        <span class="meta meta--green">Interests</span>
      </div>
      <div class="interest-strip">
        <!-- Motorsport — helmet -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <path d="M6 22c0-7 5-13 12-13s12 6 12 13v3a3 3 0 0 1-3 3H9a3 3 0 0 1-3-3z"></path>
            <path d="M10 22h6a3 3 0 0 1 3 3v3"></path>
            <line x1="11" y1="15" x2="25" y2="15"></line>
            <line x1="13" y1="11" x2="23" y2="11"></line>
          </svg>
          <span class="interest__name">Motorsport</span>
        </div>

        <!-- Board games — meeple -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <path d="M18 6c2 0 4 2 4 4s-2 4-4 4-4-2-4-4 2-4 4-4z"></path>
            <path d="M8 18c0-2 3-4 6-4l4 4 4-4c3 0 6 2 6 4l-3 4 1 8h-4l-2-6h-4l-2 6H7l1-8z"></path>
          </svg>
          <span class="interest__name">Board games</span>
        </div>

        <!-- Dinosaurs — t-rex silhouette -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <path d="M6 26c2 0 4-1 5-3l3-7c1-3 4-5 7-5h2a4 4 0 0 1 4 4v3l2 1-2 2-1 5-3 4h-3l1-4-5 2v3h-3v-3l-3-1z"></path>
            <circle class="filled" cx="25" cy="13" r="0.7"></circle>
            <line x1="14" y1="22" x2="13" y2="24"></line>
            <line x1="16" y1="22" x2="15" y2="24"></line>
          </svg>
          <span class="interest__name">Dinosaurs</span>
        </div>

        <!-- Magic — card stack -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <rect x="12" y="8" width="14" height="20" rx="1.5" transform="rotate(-10 19 18)"></rect>
            <rect x="11" y="9" width="14" height="20" rx="1.5" transform="rotate(4 18 19)"></rect>
            <line x1="14" y1="16" x2="22" y2="16"></line>
            <circle cx="18" cy="22" r="2"></circle>
          </svg>
          <span class="interest__name">Magic: TG</span>
        </div>

        <!-- D&D — d20 -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <polygon points="18,6 30,13 30,23 18,30 6,23 6,13"></polygon>
            <line x1="6" y1="13" x2="18" y2="18"></line>
            <line x1="30" y1="13" x2="18" y2="18"></line>
            <line x1="18" y1="30" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="18" y2="18"></line>
          </svg>
          <span class="interest__name">D&amp;D</span>
        </div>

        <!-- Music — eighth note -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <line x1="14" y1="8" x2="14" y2="24"></line>
            <path d="M14 8c4 2 8 4 8 9"></path>
            <ellipse class="filled" cx="11" cy="25" rx="4" ry="3"></ellipse>
          </svg>
          <span class="interest__name">Music</span>
        </div>

        <!-- Dogs — paw -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <ellipse class="filled" cx="11" cy="14" rx="2.4" ry="3"></ellipse>
            <ellipse class="filled" cx="18" cy="11" rx="2.4" ry="3"></ellipse>
            <ellipse class="filled" cx="25" cy="14" rx="2.4" ry="3"></ellipse>
            <ellipse class="filled" cx="29" cy="20" rx="2" ry="2.6"></ellipse>
            <path class="filled" d="M18 16c4 0 8 3 8 7 0 3-3 5-6 5-1 0-2-1-2-1s-1 1-2 1c-3 0-6-2-6-5 0-4 4-7 8-7z"></path>
          </svg>
          <span class="interest__name">Dogs</span>
        </div>

        <!-- Tennis — ball with seam -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 36 36" aria-hidden="true">
            <circle cx="18" cy="18" r="10"></circle>
            <path d="M9 14c4 1 8 4 9 9"></path>
            <path d="M27 22c-4-1-8-4-9-9"></path>
          </svg>
          <span class="interest__name">Tennis</span>
        </div>
      </div>
    </div>
  </div>
</section>
