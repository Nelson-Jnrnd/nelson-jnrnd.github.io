---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout title="Page not found — Nelson Jeanrenaud" description="This page is off the map.">
  <SiteHeader />
  <main class="hero" style="min-height: 50vh;">
    <div class="wrap" style="display: block; text-align: left; max-width: 60ch;">
      <div class="hero__label"><span class="meta meta--green">Off the map · 404</span></div>
      <h1>This page wandered off the field map.</h1>
      <p class="hero__sub">The waypoint you were looking for doesn’t exist — or has been re-routed.</p>
      <div class="hero__ctas">
        <a class="btn btn--primary" href="/">
          Back to base
          <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
