---
// Toolkit — the "tool roll" of concrete languages, frameworks, and platforms.
---

<section class="block toolkit-section" id="toolkit">
  <div class="wrap">
    <header class="section-head reveal">
      <span class="section-head__num">02 /</span>
      <h2 class="section-head__title">Toolkit</h2>
      <p class="section-head__caption">
        The tools, languages, and platforms I actually reach for. <span class="note-margin">starred = primary stack</span>
      </p>
    </header>

    <div class="toolroll reveal" aria-label="Tool roll">
      <div class="toolroll__grid">
        <!-- C# / .NET ★ -->
        <div class="tool tool--starred">
          <span class="tool__star" aria-label="primary stack">✦</span>
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M19 9.5a6 6 0 0 0-5-2.5 6 6 0 1 0 0 12 6 6 0 0 0 5-2.5"></path>
              <line x1="22" y1="9" x2="22" y2="17"></line>
              <line x1="25" y1="9" x2="25" y2="17"></line>
              <line x1="20" y1="11.5" x2="26.5" y2="11.5"></line>
              <line x1="20" y1="14.5" x2="26.5" y2="14.5"></line>
            </svg>
          </div>
          <span class="tool__name">C# / .NET</span>
        </div>

        <!-- ASP.NET -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <rect x="4" y="6" width="20" height="4" rx="1"></rect>
              <rect x="4" y="12" width="20" height="4" rx="1"></rect>
              <rect x="4" y="18" width="20" height="4" rx="1"></rect>
              <circle class="filled" cx="7" cy="8" r="0.9"></circle>
              <circle class="filled" cx="7" cy="14" r="0.9"></circle>
              <circle class="filled" cx="7" cy="20" r="0.9"></circle>
            </svg>
          </div>
          <span class="tool__name">ASP.NET</span>
        </div>

        <!-- Blazor ★ -->
        <div class="tool tool--starred">
          <span class="tool__star" aria-label="primary stack">✦</span>
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M15 3 L7 16 L13 16 L11 25 L21 11 L15 11 Z"></path>
            </svg>
          </div>
          <span class="tool__name">Blazor</span>
        </div>

        <!-- WPF ★ -->
        <div class="tool tool--starred">
          <span class="tool__star" aria-label="primary stack">✦</span>
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <rect x="4" y="5" width="20" height="18" rx="1"></rect>
              <line x1="14" y1="5" x2="14" y2="23"></line>
              <line x1="4" y1="14" x2="24" y2="14"></line>
              <circle class="filled" cx="6.5" cy="7.5" r="0.7"></circle>
              <circle class="filled" cx="9" cy="7.5" r="0.7"></circle>
            </svg>
          </div>
          <span class="tool__name">WPF</span>
        </div>

        <!-- Java -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M8 13 h11 v8 a3 3 0 0 1 -3 3 h-5 a3 3 0 0 1 -3 -3 z"></path>
              <path d="M19 14 h2 a2.5 2.5 0 0 1 0 5 h-2"></path>
              <path d="M11 9 c2 -2 0 -3 1 -5"></path>
              <path d="M15 9 c2 -2 0 -3 1 -5"></path>
            </svg>
          </div>
          <span class="tool__name">Java</span>
        </div>

        <!-- Python -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M9 6 h7 a3 3 0 0 1 3 3 v4 h-9 a3 3 0 0 0 -3 3 v3 a3 3 0 0 0 3 3 h2 v-4 a3 3 0 0 1 3 -3 h5 a3 3 0 0 0 3 -3 v-3 a3 3 0 0 0 -3 -3 h-2"></path>
              <circle class="filled" cx="11.5" cy="9.5" r="0.9"></circle>
              <circle class="filled" cx="16.5" cy="18.5" r="0.9"></circle>
            </svg>
          </div>
          <span class="tool__name">Python</span>
        </div>

        <!-- Jupyter -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <circle cx="14" cy="14" r="6"></circle>
              <ellipse cx="14" cy="14" rx="11" ry="4" transform="rotate(-22 14 14)"></ellipse>
              <circle class="filled" cx="22" cy="6" r="1.4"></circle>
              <circle class="filled" cx="6" cy="22" r="1.2"></circle>
            </svg>
          </div>
          <span class="tool__name">Jupyter</span>
        </div>

        <!-- Docker -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <rect x="3" y="14" width="3" height="3"></rect>
              <rect x="7" y="14" width="3" height="3"></rect>
              <rect x="11" y="14" width="3" height="3"></rect>
              <rect x="15" y="14" width="3" height="3"></rect>
              <rect x="7" y="10" width="3" height="3"></rect>
              <rect x="11" y="10" width="3" height="3"></rect>
              <rect x="11" y="6" width="3" height="3"></rect>
              <path d="M3 17 c1 4 5 5 9 5 c8 0 12 -4 13 -8 c-1 1 -3 1 -4 0"></path>
            </svg>
          </div>
          <span class="tool__name">Docker</span>
        </div>

        <!-- Kubernetes -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <polygon points="14,3 23,8 23,20 14,25 5,20 5,8"></polygon>
              <circle cx="14" cy="14" r="3"></circle>
              <line x1="14" y1="11" x2="14" y2="6"></line>
              <line x1="11" y1="13" x2="7" y2="10"></line>
              <line x1="11" y1="15" x2="7" y2="18"></line>
              <line x1="17" y1="13" x2="21" y2="10"></line>
              <line x1="17" y1="15" x2="21" y2="18"></line>
            </svg>
          </div>
          <span class="tool__name">Kubernetes</span>
        </div>

        <!-- Google Cloud -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M8 19 h13 a4 4 0 0 0 0 -8 a6 6 0 0 0 -11 -2 a4.5 4.5 0 0 0 -2 10 z"></path>
              <line x1="12" y1="14" x2="16" y2="14"></line>
              <line x1="14" y1="12" x2="14" y2="16"></line>
            </svg>
          </div>
          <span class="tool__name">Google Cloud</span>
        </div>

        <!-- AWS -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <path d="M7 18 h14 a3.5 3.5 0 0 0 0 -7 a5 5 0 0 0 -10 -1.5 a4 4 0 0 0 -4 8.5 z"></path>
              <path d="M5 22 c5 3 13 3 18 0" stroke-dasharray="1 2"></path>
              <path d="M19 23 l3 -1 l-1 3"></path>
            </svg>
          </div>
          <span class="tool__name">AWS</span>
        </div>

        <!-- Git -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <circle cx="7" cy="14" r="2"></circle>
              <circle cx="21" cy="8" r="2"></circle>
              <circle cx="21" cy="20" r="2"></circle>
              <line x1="9" y1="14" x2="19" y2="8"></line>
              <line x1="9" y1="14" x2="19" y2="20"></line>
            </svg>
          </div>
          <span class="tool__name">Git</span>
        </div>

        <!-- SQL / Databases -->
        <div class="tool">
          <div class="tool__pocket">
            <svg class="tool__icon" viewBox="0 0 28 28" aria-hidden="true">
              <ellipse cx="14" cy="7" rx="8" ry="2.5"></ellipse>
              <path d="M6 7 v6 c0 1.5 3.5 2.5 8 2.5 s8 -1 8 -2.5 v-6"></path>
              <path d="M6 13 v6 c0 1.5 3.5 2.5 8 2.5 s8 -1 8 -2.5 v-6"></path>
            </svg>
          </div>
          <span class="tool__name">SQL / DB</span>
        </div>
      </div>

      <div class="toolroll__caption">
        <span class="meta">13 tools · field-issued</span>
        <span class="annot">↳ ✦ marks the primary stack</span>
      </div>
    </div>

    <aside class="focus-note reveal" aria-label="Working-style note" style="margin-top: 28px;">
      <div class="focus-note__label">Note &mdash; working style</div>
      <p class="focus-note__text">
        “I tend to work best when I can move between understanding the domain, sketching the system, and implementing the
        details. I like when diagrams, mockups, and code all point toward the same product idea.”
      </p>
    </aside>
  </div>
</section>
