---
// About — short professional sketch + a subtle illustrated interest strip.
---

<section class="block about" id="about">
  <div class="wrap">
    <header class="section-head reveal">
      <span class="section-head__num">03 /</span>
      <h2 class="section-head__title">About</h2>
      <p class="section-head__caption">
        A short professional sketch — who I am, what I work with, and what I’m drawn to outside of work.
      </p>
    </header>

    <div class="about-grid">
      <div class="about-text reveal">
        <p>
          <strong>I’m Nelson Jeanrenaud</strong>, a software engineer based in Bussigny, Switzerland. I work mainly with
          C#/.NET, Blazor, WPF, Java, object-oriented design, and software architecture.
        </p>
        <p>
          My background includes R&amp;D software, industrial applications, backend development, teaching support in
          object-oriented programming and cloud computing, and a B.Sc. in Computer Science and Communication Systems from
          <strong>HEIG-VD</strong>, Software Development orientation, graduated in 2023.
        </p>
        <p>
          I like working on software that connects technical systems, real-world constraints, and clear user workflows. I’m
          especially interested in industrial tools, data workflows, simulation systems, and applications that need to stay
          <span class="highlight">understandable as they evolve</span>.
        </p>
      </div>
      <div class="about-media reveal">
        <figure class="polaroid">
          <div class="polaroid__frame">
            <img src="/images/laika.jpeg" alt="Laika" />
          </div>
          <figcaption class="polaroid__caption">
            <strong>Laïka, pair programmer <s>mostly emotional support</s></strong>
          </figcaption>
        </figure>
      </div>
    </div>

    <!-- ─── Interest strip ────────────────────────── -->
    <div class="interests reveal">
      <div class="interests__label">
        <span class="meta meta--green">Interests</span>
      </div>
      <div class="interest-strip">
        <!-- Motorsport — flag -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 22V4a1 1 0 0 1 .4-.8A6 6 0 0 1 8 2c3 0 5 2 7.333 2q2 0 3.067-.8A1 1 0 0 1 20 4v10a1 1 0 0 1-.4.8A6 6 0 0 1 16 16c-3 0-5-2-8-2a6 6 0 0 0-4 1.528"></path>
          </svg>
          <span class="interest__name">Motorsport</span>
        </div>

        <!-- Board games — puzzle piece -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15.39 4.39a1 1 0 0 0 1.68-.474 2.5 2.5 0 1 1 3.014 3.015 1 1 0 0 0-.474 1.68l1.683 1.682a2.414 2.414 0 0 1 0 3.414L19.61 15.39a1 1 0 0 1-1.68-.474 2.5 2.5 0 1 0-3.014 3.015 1 1 0 0 1 .474 1.68l-1.683 1.682a2.414 2.414 0 0 1-3.414 0L8.61 19.61a1 1 0 0 0-1.68.474 2.5 2.5 0 1 1-3.014-3.015 1 1 0 0 0 .474-1.68l-1.683-1.682a2.414 2.414 0 0 1 0-3.414L4.39 8.61a1 1 0 0 1 1.68.474 2.5 2.5 0 1 0 3.014-3.015 1 1 0 0 1-.474-1.68l1.683-1.682a2.414 2.414 0 0 1 3.414 0z"></path>
          </svg>
          <span class="interest__name">Board games</span>
        </div>

        <!-- Dinosaurs — footprints -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 16v-2.38C4 11.5 2.97 10.5 3 8c.03-2.72 1.49-6 4.5-6C9.37 2 10 3.8 10 5.5c0 3.11-2 5.66-2 8.68V16a2 2 0 1 1-4 0Z"></path>
            <path d="M20 20v-2.38c0-2.12 1.03-3.12 1-5.62-.03-2.72-1.49-6-4.5-6C14.63 6 14 7.8 14 9.5c0 3.11 2 5.66 2 8.68V20a2 2 0 1 0 4 0Z"></path>
            <line x1="16" y1="17" x2="20" y2="17"></line>
            <line x1="4" y1="13" x2="8" y2="13"></line>
          </svg>
          <span class="interest__name">Dinosaurs</span>
        </div>

        <!-- Magic — wand sparkles -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"></path>
            <path d="m14 7 3 3"></path>
            <path d="M5 6v4"></path>
            <path d="M19 14v4"></path>
            <path d="M10 2v2"></path>
            <path d="M7 8H3"></path>
            <path d="M21 16h-4"></path>
            <path d="M11 3H9"></path>
          </svg>
          <span class="interest__name">Magic: TG</span>
        </div>

        <!-- D&D — Simple Icons Dungeons & Dragons -->
        <div class="interest">
          <svg class="interest__icon interest__icon--brand" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3.921 2.217C4.859 1.297 6.122.742 7.988.838c2.944.152 4.358 2.096 4.672 4.438.317 2.364-.539 4.43-1.617 6.077-.317.48-.652.936-.988 1.383.582.275 1.134.633 1.62 1.099.958.918 1.591 2.198 1.629 3.782.041 1.73-.593 3.116-1.566 4.077-.972.961-2.284 1.488-3.597 1.488H1.5V1.5h2.421zm-.234 7.976h3.598c.498 0 1.056-.27 1.486-.77.434-.503.694-1.206.617-1.959-.139-1.358-1.006-2.102-2.1-2.102H3.687zm0 8.323h4.02c.679 0 1.337-.269 1.822-.748.485-.479.754-1.14.729-1.87-.048-1.393-.96-2.282-2.551-2.282H3.687zM22.5 12c0 5.795-4.705 10.5-10.5 10.5v-2.484c4.443 0 8.016-3.573 8.016-8.016S16.443 3.984 12 3.984V1.5C17.795 1.5 22.5 6.205 22.5 12"></path>
          </svg>
          <span class="interest__name">D&amp;D</span>
        </div>

        <!-- Music — music note -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
          <span class="interest__name">Music</span>
        </div>

        <!-- Dogs — paw print -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="4" r="2"></circle>
            <circle cx="18" cy="8" r="2"></circle>
            <circle cx="20" cy="16" r="2"></circle>
            <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"></path>
          </svg>
          <span class="interest__name">Dogs</span>
        </div>

        <!-- Tennis — ball with seam -->
        <div class="interest">
          <svg class="interest__icon" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M4.93 19.07A10 10 0 0 0 4.93 4.93"></path>
            <path d="M19.07 4.93A10 10 0 0 0 19.07 19.07"></path>
          </svg>
          <span class="interest__name">Tennis</span>
        </div>
      </div>
    </div>
  </div>
</section>
