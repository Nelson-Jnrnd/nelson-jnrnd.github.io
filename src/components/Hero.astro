---
// Hero — intro + portrait polaroid. The site map navigation lives in the header.
---

<section class="hero">
  <div class="wrap">
    <div class="hero__left reveal">
      <div class="hero__label">
        <span class="meta meta--green">Field notes — Vol. 01 · 2026</span>
      </div>
      <h1>
        Software engineer focused on architecture, <span class="ink-mark">.NET applications</span>, and industrial software.
      </h1>
      <p class="hero__sub">
        I’m Nelson Jeanrenaud, a software engineer based in Bussigny, Switzerland. I work with C#/.NET, Blazor, WPF, Java,
        object-oriented design, software architecture, and technical applications.
      </p>
      <p class="hero__supporting">
        I enjoy building software for technical domains, especially when it involves understanding how things work, shaping
        messy ideas into usable tools, and keeping systems clear as they grow.
      </p>
      <div class="hero__ctas">
        <a class="btn btn--primary" href="#work">
          View work
          <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a class="btn" href="#contact">Contact me</a>
      </div>
      <span class="hero__loc">
        <svg class="loc-icon" viewBox="0 0 12 14" aria-hidden="true">
          <path d="M6 .8C3.2.8 1 3 1 5.7c0 3.6 5 7.5 5 7.5s5-3.9 5-7.5C11 3 8.8.8 6 .8z" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
          <circle cx="6" cy="5.7" r="1.6" fill="currentColor"></circle>
        </svg>
        Based in Bussigny, Switzerland
        <span style="color: var(--line-strong); margin: 0 4px;">·</span>
        open to roles &amp; technical projects
      </span>
    </div>

    <aside class="hero__right reveal">
      <!-- Portrait polaroid (site map navigation lives in the top-right corner of the header) -->
      <figure class="polaroid polaroid--hero" aria-label="Portrait placeholder">
        <div class="polaroid__frame">
          <!-- abstract portrait sketch placeholder -->
          <svg class="sketch" viewBox="0 0 100 120" aria-hidden="true">
            <circle cx="50" cy="42" r="18"></circle>
            <path d="M22 110c0-18 12-30 28-30s28 12 28 30"></path>
            <path d="M40 42c2-3 5-4 10-4s8 1 10 4"></path>
            <line x1="38" y1="36" x2="44" y2="36"></line>
            <line x1="56" y1="36" x2="62" y2="36"></line>
          </svg>
        </div>
        <figcaption class="polaroid__caption">
          <strong>portrait — placeholder</strong>
          <span>4:5 · public/images/portrait</span>
        </figcaption>
      </figure>
      <p class="hero__portrait-note">
        <span class="annot">↳ Nelson, circa 2026</span>
      </p>
    </aside>
  </div>
</section>
